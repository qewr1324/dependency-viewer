{
	"name": "dependency-viewer",
	"type": "module",
	"displayName": "Dependency Viewer",
	"description": "🍂 Dependency Viewer - Graphical dependency manager for Java, Node.js, Python and more for 💠 VSCode. ",
	"version": "1.0.3",
	"private": false,
	"publisher": "GhurbeSABZI",
	"packageManager": "bun@1.3.14",
	"author": "GhurbeSABZI <naiad.arts.studio@gmail.com>",
	"icon": "res/facet-icon-big.png",
	"license": "MIT",
	"homepage": "https://github.com/qewr1324/dependency-viewer#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/qewr1324/dependency-viewer"
	},
	"bugs": {
		"url": "https://github.com/qewr1324/dependency-viewer/issues"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"keywords": [
		"dependency",
		"language dependency",
		"package manager",
		"npm",
		"maven",
		"pypi",
		"nuget",
		"packagist",
		"rubygems",
		"crates",
		"golang",
		"pubdev",
		"swiftpm"
	],
	"categories": [
		"Other"
	],
	"galleryBanner": {
		"color": "#0D1117",
		"theme": "dark"
	},
	"preview": false,
	"qna": "marketplace",
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.cjs",
	"contributes": {
		"commands": [
			{
				"command": "dependencyManager.openPanel",
				"title": "Dependency Viewer: Open Panel",
				"icon": "$(package)"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "bun run build",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"build": "tsdown src/extension.ts --external vscode && cp route.json dist/route.json && mkdir -p dist/panel && cp src/panel/webview.html dist/panel/webview.html && cp src/panel/styles.css dist/panel/styles.css && cp src/panel/main.js dist/panel/main.js",
		"dev": "tsdown src/extension.ts --external vscode --watch --sourcemap",
		"prepare": "echo 'Skipping update'",
		"update": "echo 'Skipping vscode-ext-gen'",
		"lint": "eslint .",
		"test": "vitest",
		"typecheck": "tsc --noEmit",
		"release": "bumpp",
		"ext:package": "vsce package --no-dependencies",
		"ext:publish": "vsce publish --no-dependencies"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^6.7.3",
		"@antfu/ni": "^28.0.0",
		"@types/node": "^20.19.43",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^3.7.1",
		"bumpp": "^10.3.2",
		"eslint": "^9.39.2",
		"ovsx": "^0.10.7",
		"reactive-vscode": "^1.0.0-beta.2",
		"taze": "^19.9.2",
		"tsdown": "^0.19.0-beta.3",
		"typescript": "^5.3.0",
		"vite": "^7.3.0",
		"vitest": "^4.0.16",
		"vscode-ext-gen": "^1.5.1",
		"vsxpub": "^0.1.2"
	}
}
