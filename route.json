{
	"Java": {
		"maven": {
			"name": "Maven Central",
			"searchUrl": "https://search.maven.org/solrsearch/select",
			"params": {
				"q": "${query}",
				"rows": "20",
				"wt": "json"
			},
			"parseResponse": {
				"items": "response.docs",
				"version": ["latestVersion"],
				"format": "<dependency>\n    <groupId>{groupId}</groupId>\n    <artifactId>{artifactId}</artifactId>\n    <version>{version}</version>\n</dependency>"
			}
		}
	},
	"JavaScript": {
		"npm": {
			"name": "npm Registry",
			"searchUrl": "https://registry.npmjs.org/-/v1/search",
			"params": {
				"text": "${query}",
				"size": "20"
			},
			"parseResponse": {
				"items": "objects",
				"version": ["package", "version"],
				"format": "\"{name}\": \"^{version}\""
			}
		}
	},
	"TypeScript": {
		"npm-types": {
			"name": "npm (@types)",
			"searchUrl": "https://registry.npmjs.org/-/v1/search",
			"params": {
				"text": "@types/${query}",
				"size": "20"
			},
			"parseResponse": {
				"items": "objects",
				"version": ["package", "version"],
				"format": "\"{name}\": \"^{version}\""
			}
		}
	},
	"C#": {
		"nuget": {
			"name": "NuGet Gallery",
			"searchUrl": "https://azuresearch-usnc.nuget.org/query",
			"params": {
				"q": "${query}",
				"take": "20",
				"prerelease": "false"
			},
			"parseResponse": {
				"items": "data",
				"version": ["version"],
				"format": "<PackageReference Include=\"{name}\" Version=\"{version}\" />"
			}
		}
	},
	"Ruby": {
		"rubygems": {
			"name": "RubyGems",
			"searchUrl": "https://rubygems.org/api/v1/search.json",
			"params": {
				"query": "${query}"
			},
			"parseResponse": {
				"items": "root",
				"version": ["version"],
				"format": "gem '{name}', '~> {version}'"
			}
		}
	},
	"Rust": {
		"crates": {
			"name": "crates.io",
			"searchUrl": "https://crates.io/api/v1/crates",
			"params": {
				"q": "${query}",
				"per_page": "20"
			},
			"parseResponse": {
				"items": "crates",
				"version": ["max_version"],
				"format": "{name} = \"{version}\""
			}
		}
	},
	"Kotlin": {
		"maven-kotlin": {
			"name": "Maven Central",
			"searchUrl": "https://search.maven.org/solrsearch/select",
			"params": {
				"q": "${query}",
				"rows": "20",
				"wt": "json"
			},
			"parseResponse": {
				"items": "response.docs",
				"version": ["latestVersion"],
				"format": "implementation(\"{groupId}:{artifactId}:{version}\")"
			}
		}
	},
	"Groovy": {
		"maven-groovy": {
			"name": "Maven Central",
			"searchUrl": "https://search.maven.org/solrsearch/select",
			"params": {
				"q": "${query}",
				"rows": "20",
				"wt": "json"
			},
			"parseResponse": {
				"items": "response.docs",
				"version": ["latestVersion"],
				"format": "implementation '{groupId}:{artifactId}:{version}'"
			}
		}
	}
}
